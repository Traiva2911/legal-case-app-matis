{
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["reader"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "no-referrer",
    "Cache-Control": "no-store"
  },
  "navigationFallback": {
    "rewrite": "/index.html"
  }
}
